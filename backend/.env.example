# Backend ke environment variables. Local ke liye is file ko ".env" naam se copy karo:
#   cp .env.example .env

# --- LLM provider (OpenAI-compatible) ---
API_KEY=your-key-here
BASE_URL=https://api.openai.com/v1
MODEL=gpt-4o-mini

# Speech-to-Text model. Voice input (Groq Whisper) ke liye.
# Groq use kar rahe ho tabhi chalega (BASE_URL groq wala ho).
STT_MODEL=whisper-large-v3-turbo

# Agar DeepSeek key hai to:
# BASE_URL=https://api.deepseek.com
# MODEL=deepseek-chat
#
# Groq (voice ke liye recommended — STT yahi support karta hai):
# BASE_URL=https://api.groq.com/openai/v1
# MODEL=llama-3.3-70b-versatile

# --- Database (Neon) — optional. Khali chhodo to in-memory chalega. ---
# Neon dashboard se connection string copy karo (sslmode=require ke saath).
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require

# --- Email (Gmail SMTP) — agent ke send_email tool ke liye ---
# Gmail App Password banao: https://myaccount.google.com/apppasswords (2FA on hona chahiye).
# SMTP_PASS khali chhoda to agent draft to banayega par bhejega nahi.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tyagianant98@gmail.com
SMTP_PASS=
MAIL_FROM=tyagianant98@gmail.com

# --- CORS: production me apna Vercel frontend URL daalo (comma se alag) ---
# ALLOWED_ORIGINS=https://my-agent.vercel.app
ALLOWED_ORIGINS=*
